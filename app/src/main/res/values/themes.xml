<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AgentApp" parent="android:Theme.Material.NoTitleBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/obsidian</item>
    </style>

    <style name="Theme.AgentApp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/obsidian</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_notification</item>
        <item name="postSplashScreenTheme">@style/Theme.AgentApp</item>
    </style>
</resources>
